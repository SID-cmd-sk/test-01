{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/processing.result.json",
  "title": "ProcessingResult",
  "type": "object",
  "required": ["jobId", "documentType", "pageCount", "entities"],
  "properties": {
    "jobId": { "type": "string" },
    "documentType": { "type": "string", "enum": ["raster", "vector", "hybrid"] },
    "pageCount": { "type": "integer", "minimum": 1 },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entityId", "type", "geometry"],
        "properties": {
          "entityId": { "type": "string" },
          "type": { "type": "string", "enum": ["line", "polyline", "arc", "circle", "text"] },
          "layerHint": { "type": "string" },
          "geometry": { "type": "object" },
          "text": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
