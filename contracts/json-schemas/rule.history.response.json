{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/rule.history.response.json",
  "title": "RuleHistoryResponse",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "createdAt", "author", "summary", "active"],
        "properties": {
          "ruleId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "author": { "type": "string" },
          "summary": { "type": "string" },
          "active": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
